prod:Lighting rdf:type owl:Class .


###  https://w3id.org/product#PendantLighting
prod:PendantLighting rdf:type owl:Class .


###  https://w3id.org/product#Pipe
prod:Pipe rdf:type owl:Class .


###  https://w3id.org/product#Product
prod:Product rdf:type owl:Class .


###  https://w3id.org/product#Pump
prod:Pump rdf:type owl:Class .


###  https://w3id.org/product#Railing
prod:Railing rdf:type owl:Class .


###  https://w3id.org/product#Roof
prod:Roof rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Class ;
                                owl:unionOf ( ifc:IfcRoof
                                              [ owl:intersectionOf ( ifc:IfcCovering
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty ifc:predefinedType_IfcCovering ;
                                                                       owl:hasValue ifc:ROOFING
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ]
                                              [ owl:intersectionOf ( ifc:IfcSlab
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty ifc:predefinedType_IfcSlab ;
                                                                       owl:hasValue ifc:ROOF
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ]
                                            )
                              ] .


###  https://w3id.org/product#RoofCovering
prod:RoofCovering rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty ifc:predefinedType_IfcCovering ;
                                                               owl:hasValue ifc:ROOFING
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] .


###  https://w3id.org/product#Slab
prod:Slab rdf:type owl:Class .


###  https://w3id.org/product#Stair
prod:Stair rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:unionOf ( ifc:IfcStair
                                               ifc:IfcStairFlight
                                             )
                               ] .


###  https://w3id.org/product#StairStringer
prod:StairStringer rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( ifc:IfcMember
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty ifc:predefinedType_IfcMember ;
                                                                owl:hasValue ifc:STRINGER
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] .


###  https://w3id.org/product#StairThread
prod:StairThread rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( ifc:IfcMember
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty ifc:predefinedType_IfcMember ;
                                                              owl:hasValue ifc:LANDING
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] .


###  https://w3id.org/product#Valve
prod:Valve rdf:type owl:Class .


###  https://w3id.org/product#VerticalTransportationDevice
prod:VerticalTransportationDevice rdf:type owl:Class .


###  https://w3id.org/product#Wall
prod:Wall rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Class ;
                                owl:unionOf ( ifc:IfcWall
                                              ifc:IfcWallElementedCase
                                              ifc:IfcWallStandardCase
                                            )
                              ] .


###  https://w3id.org/product#WallCovering
prod:WallCovering rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty ifc:predefinedType_IfcCovering ;
                                                               owl:hasValue ifc:CLADDING
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] .


###  https://w3id.org/product#Window
prod:Window rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround
bc:AboveGround rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty ifcLit:hasPropertySingleValue ;
                                     owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty ifcLit:hasName ;
                                                                                 owl:hasValue "AboveGround"
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty ifcLit:hasValue_IfcPropertySingleValue ;
                                                                                 owl:hasValue "true"^^xsd:boolean
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ]
                                   ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent
bc:BuildingComponent rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType
bc:BuildingComponentType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Equipment
bc:Equipment rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Class ;
                                   owl:unionOf ( ifc:IfcEnergyConversionDevice
                                                 ifc:IfcFlowMovingDevice
                                               )
                                 ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#External
bc:External rdf:type owl:Class ;
            owl:equivalentClass [ rdf:type owl:Restriction ;
                                  owl:onProperty ifcLit:hasPropertySingleValue ;
                                  owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                              owl:onProperty ifcLit:hasName ;
                                                                              owl:hasValue "IsExternal"
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty ifcLit:hasValue_IfcPropertySingleValue ;
                                                                              owl:hasValue "true"^^xsd:boolean
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ]
                                ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Internal
bc:Internal rdf:type owl:Class ;
            owl:equivalentClass [ rdf:type owl:Restriction ;
                                  owl:onProperty ifcLit:hasPropertySingleValue ;
                                  owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                              owl:onProperty ifcLit:hasName ;
                                                                              owl:hasValue "IsExternal"
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty ifcLit:hasValue_IfcPropertySingleValue ;
                                                                              owl:hasValue "false"^^xsd:boolean
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ]
                                ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#LateralBrace
bc:LateralBrace rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty ifc:predefinedType_IfcMember ;
                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                       owl:oneOf ( ifc:BRACE
                                                                   ifc:STRUT
                                                                 )
                                                     ]
                                ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#LoadBearing
bc:LoadBearing rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty ifcLit:hasPropertySingleValue ;
                                     owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty ifcLit:hasName ;
                                                                                 owl:hasValue "LoadBearing"
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty ifcLit:hasValue_IfcPropertySingleValue ;
                                                                                 owl:hasValue "true"^^xsd:boolean
