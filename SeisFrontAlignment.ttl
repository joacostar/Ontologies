@prefix : <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .
@prefix bc: <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix ifc: <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix om2: <http://www.ontology-of-units-of-measure.org/resource/om-2/subset#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sfa: <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dicm: <https://w3id.org/digitalconstruction/0.5/Materials/Subset#> .
@prefix prod: <https://w3id.org/product#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ifcLit: <https://w3id.org/utoronto/ontologies/IfcLit#> .
@prefix sfront: <https://w3id.org/utoronto/ontologies/SeisFront#> .
@base <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .

<https://w3id.org/utoronto/ontologies/SeisFrontAlignment> rdf:type owl:Ontology ;
                                                           owl:imports <http://www.ontology-of-units-of-measure.org/resource/om-2/subset> ,
                                                                       <https://w3id.org/utoronto/ontologies/BuildingComponents> ,
                                                                       <https://w3id.org/utoronto/ontologies/IfcLit> ,
                                                                       <https://w3id.org/utoronto/ontologies/SeisFront> ,
                                                                       <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL> ,
                                                                       <https://w3id.org/digitalconstruction/0.5/Materials/Subset> .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute
<https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute> rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterial
<https://w3id.org/utoronto/ontologies/IfcLit#hasMaterial> rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterialReference
<https://w3id.org/utoronto/ontologies/IfcLit#hasMaterialReference> rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalComplexQuantity
<https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalComplexQuantity> rdf:type owl:ObjectProperty ;
                                                                                         rdfs:subPropertyOf <https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute> .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalSimpleQuantity
<https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalSimpleQuantity> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:subPropertyOf <https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute> ;
                                                                                        owl:inverseOf sfa:isPhysicalQuantityOf .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasProperty
<https://w3id.org/utoronto/ontologies/IfcLit#hasProperty> rdf:type owl:ObjectProperty ;
                                                                          rdfs:subPropertyOf <https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute> .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue
<https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:subPropertyOf <https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute> ;
                                                                                     owl:inverseOf sfa:isPropertyOf .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#hasUnitWithName
sfa:hasUnitWithName rdf:type owl:ObjectProperty ;
                    owl:propertyChainAxiom ( ifc:unit_IfcPropertySingleValue
                                             ifc:name_IfcSIUnit
                                           ) .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#isPhysicalQuantityOf
sfa:isPhysicalQuantityOf rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#isPropertyOf
sfa:isPropertyOf rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/IfcLit#hasName
<https://w3id.org/utoronto/ontologies/IfcLit#hasName> rdf:type owl:DatatypeProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue
<https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue> rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround
<https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround> rdf:type owl:Class ;
                                                                                       owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue> ;
                                                                                                             owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                                                         owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasName> ;
                                                                                                                                                         owl:hasValue "AboveGround"
                                                                                                                                                       ]
                                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                                         owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue> ;
                                                                                                                                                         owl:hasValue "true"^^xsd:boolean
                                                                                                                                                       ]
                                                                                                                                                     ) ;
                                                                                                                                  rdf:type owl:Class
                                                                                                                                ]
                                                                                                           ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent
<https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent> rdf:type owl:Class ;
                                                                                             owl:equivalentClass ifc:IfcElement .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType
<https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType> rdf:type owl:Class ;
                                                                                                 owl:equivalentClass ifc:IfcElementType .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Equipment
<https://w3id.org/utoronto/ontologies/BuildingComponents#Equipment> rdf:type owl:Class ;
                                                                                     owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                           owl:unionOf ( ifc:IfcEnergyConversionDevice
                                                                                                                         ifc:IfcFlowMovingDevice
                                                                                                                       )
                                                                                                         ] .


