@prefix : <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .
@prefix bc: <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix ifc: <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix om2: <http://www.ontology-of-units-of-measure.org/resource/om-2/subset#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sfa: <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dicm: <https://w3id.org/digitalconstruction/0.5/Materials/Subset#> .
@prefix prod: <https://w3id.org/product#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ifcLit: <https://w3id.org/utoronto/ontologies/IfcLit#> .
@prefix sfront: <https://w3id.org/utoronto/ontologies/SeisFront#> .
@base <https://w3id.org/utoronto/ontologies/SeisFrontAlignment#> .

<https://w3id.org/utoronto/ontologies/SeisFrontAlignment> rdf:type owl:Ontology ;
                                                           owl:imports <http://www.ontology-of-units-of-measure.org/resource/om-2/subset> ,
                                                                       <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL> ,
                                                                       <https://w3id.org/digitalconstruction/0.5/Materials/Subset> ,
                                                                       <https://w3id.org/utoronto/ontologies/BuildingComponents> ,
                                                                       <https://w3id.org/utoronto/ontologies/IfcLit> ,
                                                                       <https://w3id.org/utoronto/ontologies/SeisFront> ;
                                                           <http://purl.org/dc/elements/1.1/creator> "Joaquín Acosta Reveco (j.acosta@mail.utoronto.ca)" ;
                                                           rdfs:label "Alignment Ontology SeisFront-ifcOWL" .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute
bc:hasAttribute rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterial
ifcLit:hasMaterial rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterialReference
ifcLit:hasMaterialReference rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalComplexQuantity
ifcLit:hasPhysicalComplexQuantity rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf bc:hasAttribute .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalSimpleQuantity
ifcLit:hasPhysicalSimpleQuantity rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf bc:hasAttribute ;
                                 owl:inverseOf sfa:isPhysicalQuantityOf .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasProperty
ifcLit:hasProperty rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf bc:hasAttribute .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue
ifcLit:hasPropertySingleValue rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf bc:hasAttribute ;
                              owl:inverseOf sfa:isPropertyOf .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#hasUnitWithName
sfa:hasUnitWithName rdf:type owl:ObjectProperty ;
                    owl:propertyChainAxiom ( ifc:unit_IfcPropertySingleValue
                                             ifc:name_IfcSIUnit
                                           ) .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#isPhysicalQuantityOf
sfa:isPhysicalQuantityOf rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/SeisFrontAlignment#isPropertyOf
sfa:isPropertyOf rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/IfcLit#hasName
ifcLit:hasName rdf:type owl:DatatypeProperty .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue
ifcLit:hasValue_IfcPropertySingleValue rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcBeam
ifc:IfcBeam owl:equivalentClass prod:Beam .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcChiller
ifc:IfcChiller owl:equivalentClass prod:Chiller .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcCoil
ifc:IfcCoil owl:equivalentClass prod:Coil .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcColumn
ifc:IfcColumn owl:equivalentClass prod:Column .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcCompressor
ifc:IfcCompressor owl:equivalentClass prod:AirCompressor .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcCoolingTower
ifc:IfcCoolingTower owl:equivalentClass prod:CoolingTower .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcCovering
ifc:IfcCovering owl:equivalentClass prod:Covering ,
                                    prod:Finishing .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcCurtainWall
ifc:IfcCurtainWall owl:equivalentClass prod:CurtainWall .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcDoor
ifc:IfcDoor owl:equivalentClass prod:Door .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcDuctSegment
ifc:IfcDuctSegment owl:equivalentClass prod:Duct .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcElement
ifc:IfcElement owl:equivalentClass bc:BuildingComponent .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcElementType
ifc:IfcElementType owl:equivalentClass bc:BuildingComponentType .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcFan
ifc:IfcFan owl:equivalentClass prod:Fan .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcFurniture
ifc:IfcFurniture owl:equivalentClass prod:Furnishing .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcLightFixture
ifc:IfcLightFixture owl:equivalentClass prod:Lighting ,
                                        prod:PendantLighting .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcPipeFitting
ifc:IfcPipeFitting owl:equivalentClass prod:Fitting .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcPipeSegment
ifc:IfcPipeSegment owl:equivalentClass prod:Pipe .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcProduct
ifc:IfcProduct owl:equivalentClass prod:Product .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcPump
ifc:IfcPump owl:equivalentClass prod:Pump .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcRailing
ifc:IfcRailing owl:equivalentClass prod:Railing .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcSlab
ifc:IfcSlab owl:equivalentClass prod:Slab .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcTransportElement
ifc:IfcTransportElement owl:equivalentClass prod:VerticalTransportationDevice .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcValve
ifc:IfcValve owl:equivalentClass prod:Valve .


###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcWindow
ifc:IfcWindow owl:equivalentClass prod:Window .


###  https://w3id.org/product#AirCompressor
prod:AirCompressor rdf:type owl:Class .


###  https://w3id.org/product#AirHandlingUnit
prod:AirHandlingUnit rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( ifc:IfcUnitaryEquipment
                                                                [ rdf:type owl:Class ;
                                                                  owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty ifc:predefinedType_IfcUnitaryEquipment ;
                                                                                  owl:hasValue ifc:AIRHANDLER
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty ifc:predefinedType_IfcUnitaryEquipment ;
                                                                                  owl:hasValue ifc:ROOFTOPUNIT
                                                                                ]
                                                                              )
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] .


###  https://w3id.org/product#Beam
prod:Beam rdf:type owl:Class .


###  https://w3id.org/product#Brace
prod:Brace rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( ifc:IfcMember
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty ifc:predefinedType_IfcMember ;
                                                        owl:hasValue ifc:BRACE
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] .


###  https://w3id.org/product#Ceiling
prod:Ceiling rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty ifc:predefinedType_IfcCovering ;
                                                          owl:hasValue ifc:CEILING
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] .


###  https://w3id.org/product#Chiller
prod:Chiller rdf:type owl:Class .


###  https://w3id.org/product#Coil
prod:Coil rdf:type owl:Class .


###  https://w3id.org/product#Column
prod:Column rdf:type owl:Class .


###  https://w3id.org/product#ColumnCovering
prod:ColumnCovering rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty ifc:predefinedType_IfcCovering ;
                                                                 owl:hasValue ifc:CLADDING
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] .


###  https://w3id.org/product#ControlPanel
prod:ControlPanel rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( ifc:IfcUnitaryControlElement
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty ifc:predefinedType_IfcUnitaryControlElement ;
                                                               owl:hasValue ifc:CONTROLPANEL
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] .


###  https://w3id.org/product#CoolingTower
prod:CoolingTower rdf:type owl:Class .


###  https://w3id.org/product#Covering
prod:Covering rdf:type owl:Class .


###  https://w3id.org/product#CurtainWall
prod:CurtainWall rdf:type owl:Class .


###  https://w3id.org/product#Difusser
prod:Difusser rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( ifc:IfcAirTerminal
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty ifc:predefinedType_IfcAirTerminal ;
                                                           owl:hasValue ifc:DIFFUSER
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] .


###  https://w3id.org/product#DistributionPanel
prod:DistributionPanel rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( ifc:IfcElectricDistributionBoard
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty ifc:predefinedType_IfcElectricDistributionBoard ;
                                                                    owl:hasValue ifc:DISTRIBUTIONBOARD
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] .


###  https://w3id.org/product#Door
prod:Door rdf:type owl:Class .


###  https://w3id.org/product#Duct
prod:Duct rdf:type owl:Class .


###  https://w3id.org/product#DuctTransition
prod:DuctTransition rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( ifc:IfcDuctFitting
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty ifc:predefinedType_IfcDuctFitting ;
                                                                 owl:hasValue ifc:TRANSITION
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] .


###  https://w3id.org/product#Elevator
prod:Elevator rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( ifc:IfcTransportElement
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty ifc:predefinedType_IfcTransportElement ;
                                                           owl:hasValue ifc:ELEVATOR
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] .


###  https://w3id.org/product#Fan
prod:Fan rdf:type owl:Class .


###  https://w3id.org/product#Finishing
prod:Finishing rdf:type owl:Class .


###  https://w3id.org/product#FireSprinklerDrop
prod:FireSprinklerDrop rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( ifc:IfcFireSuppressionTerminal
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty ifc:predefinedType_IfcFireSuppressionTerminal ;
                                                                    owl:hasValue ifc:SPRINKLER
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] .


###  https://w3id.org/product#Fitting
prod:Fitting rdf:type owl:Class .


###  https://w3id.org/product#Floor
prod:Floor rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:unionOf ( [ owl:intersectionOf ( ifc:IfcCovering
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty ifc:predefinedType_IfcCovering ;
                                                                        owl:hasValue ifc:FLOORING
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ]
                                               [ owl:intersectionOf ( ifc:IfcSlab
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty ifc:predefinedType_IfcSlab ;
                                                                        owl:hasValue ifc:FLOOR
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ]
                                             )
                               ] .


###  https://w3id.org/product#FloorCovering
prod:FloorCovering rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty ifc:predefinedType_IfcCovering ;
                                                                owl:hasValue ifc:FLOORING
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] .


###  https://w3id.org/product#Foundation
prod:Foundation rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:unionOf ( ifc:IfcFooting
                                                    [ owl:intersectionOf ( ifc:IfcSlab
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty ifc:predefinedType_IfcSlab ;
                                                                             owl:hasValue ifc:BASESLAB
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ]
                                                  )
                                    ] .


###  https://w3id.org/product#Furnishing
prod:Furnishing rdf:type owl:Class .


###  https://w3id.org/product#InsulationCovering
prod:InsulationCovering rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( ifc:IfcCovering
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty ifc:predefinedType_IfcCovering ;
                                                                     owl:hasValue ifc:INSULATION
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] .


###  https://w3id.org/product#Lift
prod:Lift rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( ifc:IfcTransportElement
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty ifc:predefinedType_IfcTransportElement ;
                                                       owl:hasValue ifc:LIFTINGGEAR
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] .


