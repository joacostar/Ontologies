                                                                                                          owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue> ;
                                                                                                          owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                                                      owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasName> ;
                                                                                                                                                      owl:hasValue "IsExternal"
                                                                                                                                                    ]
                                                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                                                      owl:onProperty <https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue> ;
                                                                                                                                                      owl:hasValue "true"^^xsd:boolean
                                                                                                                                                    ]
                                                                                                                                                  ) ;
