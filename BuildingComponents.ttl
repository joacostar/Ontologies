###  https://w3id.org/utoronto/ontologies/BuildingComponents#Infilled
bc:Infilled rdf:type owl:Class ;
            owl:equivalentClass [ rdf:type owl:Restriction ;
                                  owl:onProperty dicm:hasLayer ;
                                  owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                       owl:onProperty dicm:hasMaterial ;
                                                       owl:someValuesFrom dicm:Material
                                                     ]
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty bc:hasInfill ;
                                  owl:someValuesFrom bc:WallInfill
                                ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#InteriorComponent
bc:InteriorComponent rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bc:BuildingComponent
