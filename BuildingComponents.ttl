@prefix : <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix bc: <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix om2: <http://www.ontology-of-units-of-measure.org/resource/om-2/subset/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dicm: <https://w3id.org/digitalconstruction/0.5/Materials/Subset#> .
@prefix prod: <https://w3id.org/product#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/utoronto/ontologies/BuildingComponents#> .

<https://w3id.org/utoronto/ontologies/BuildingComponents> rdf:type owl:Ontology ;
                                                           owl:imports <http://www.ontology-of-units-of-measure.org/resource/om-2/subset> ,
                                                                       <https://w3id.org/digitalconstruction/0.5/Materials/Subset> ,
                                                                       prod:BuildingElements ,
                                                                       prod:Furnishing ,
                                                                       prod:MEP .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute
bc:hasAttribute rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( bc:BuildingComponent
                                            bc:BuildingComponentType
                                          )
                            ] ;
                rdfs:range bc:ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasComponent
bc:hasComponent rdf:type owl:ObjectProperty ;
                owl:inverseOf bc:isComponentOf ;
                rdf:type owl:TransitiveProperty ;
                rdfs:domain bc:BuildingProduct .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasFrame
bc:hasFrame rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasInfill
bc:hasInfill rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasQuantity
bc:hasQuantity rdf:type owl:ObjectProperty ;
               rdfs:domain bc:ComponentAttribute ;
               rdfs:range bc:Quantity .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasSealant
bc:hasSealant rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasSupport
bc:hasSupport rdf:type owl:ObjectProperty ;
              rdfs:domain bc:BuildingComponent ;
              rdfs:range bc:Restraint .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasUnit
bc:hasUnit rdf:type owl:ObjectProperty ;
           rdfs:domain bc:Quantity ;
           rdfs:range bc:Unit .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isComponentOf
bc:isComponentOf rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isInSystemOfType
bc:isInSystemOfType rdf:type owl:ObjectProperty ;
                    rdfs:domain bc:BuildingComponent ;
                    rdfs:range bc:MepSystemType .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAspectRatio
bc:hasAspectRatio rdf:type owl:DatatypeProperty ;
                  rdfs:domain bc:BuildingComponent ;
                  rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasDouble
bc:hasDouble rdf:type owl:DatatypeProperty ;
             rdfs:domain bc:Quantity ;
             rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isAboveGround
bc:isAboveGround rdf:type owl:DatatypeProperty ;
                 rdfs:domain bc:BuildingComponent ;
                 rdfs:range xsd:boolean ;
                 owl:propertyDisjointWith bc:isBelowGround .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isBelowGround
bc:isBelowGround rdf:type owl:DatatypeProperty ;
                 rdfs:domain bc:BuildingComponent ;
                 rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isExternal
bc:isExternal rdf:type owl:DatatypeProperty ;
              rdfs:domain bc:BuildingComponent ;
              rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isInternal
bc:isInternal rdf:type owl:DatatypeProperty ;
              rdfs:domain bc:BuildingComponent ;
              rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isLoadBearing
bc:isLoadBearing rdf:type owl:DatatypeProperty ;
                 rdfs:domain bc:BuildingComponent ;
                 rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isMonolithic
bc:isMonolithic rdf:type owl:DatatypeProperty ;
                rdfs:domain bc:BuildingComponent ;
                rdfs:range xsd:boolean .


#################################################################
#    Classes
#################################################################

###  http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Diameter
om2:Diameter rdf:type owl:Class .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Thickness
om2:Thickness rdf:type owl:Class .


###  https://w3id.org/product#AirCompressor
prod:AirCompressor rdf:type owl:Class ;
                   rdfs:subClassOf prod:Product ,
                                   bc:AirDistributionComponent ,
                                   bc:BuildingComponent ;
                   rdfs:label "AirCompressor"@en .


###  https://w3id.org/product#AirHandlingUnit
prod:AirHandlingUnit rdf:type owl:Class ;
                     rdfs:subClassOf prod:Product ,
                                     bc:AirDistributionComponent ,
                                     bc:BuildingComponent ;
                     rdfs:label "AirHandlingUnit"@en .


###  https://w3id.org/product#AnnealedGlassPanel
prod:AnnealedGlassPanel rdf:type owl:Class ;
                        rdfs:subClassOf prod:GlassPanel ;
                        rdfs:label "Annealed Glass Panel" .


