                                                                     [ rdf:type owl:Class ;
                                                                       owl:complementOf bc:MepComponent
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf bc:BuildingComponent ;
                          owl:disjointWith bc:StructuralComponent .


