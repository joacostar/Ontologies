###  https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround
bc:AboveGround rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty bc:isAboveGround ;
                                     owl:hasValue "true"^^xsd:boolean
                                   ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#AirDistributionComponent
bc:AirDistributionComponent rdf:type owl:Class ;
                            rdfs:subClassOf bc:MepComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround
bc:BelowGround rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty bc:isAboveGround ;
                                     owl:hasValue "false"^^xsd:boolean
                                   ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Building
bc:Building rdf:type owl:Class ;
            rdfs:subClassOf bc:BuildingProduct ;
            owl:disjointWith bc:BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent
bc:BuildingComponent rdf:type owl:Class ;
                     rdfs:subClassOf prod:Product ,
                                     bc:BuildingProduct .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType
bc:BuildingComponentType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingProduct
bc:BuildingProduct rdf:type owl:Class ;
                   rdfs:subClassOf prod:Product .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Clearance
bc:Clearance rdf:type owl:Class ;
             rdfs:subClassOf bc:ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ColdFormedFrame
bc:ColdFormedFrame rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bc:Frame
                                                              bc:MadeOfColdFormedSteel
                                                            ) ;
                                         rdf:type owl:Class
                                       ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ColdFormedSteelFramed
bc:ColdFormedSteelFramed rdf:type owl:Class ;
                         owl:equivalentClass [ rdf:type owl:Restriction ;
                                               owl:onProperty bc:hasFrame ;
                                               owl:someValuesFrom bc:ColdFormedFrame
                                             ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ComponentAttribute
bc:ComponentAttribute rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Ducting
bc:Ducting rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:unionOf ( prod:Duct
                                               prod:DuctTransition
                                               prod:Fitting
                                             )
                               ] ;
           rdfs:subClassOf bc:AirDistributionComponent ,
                           bc:MepComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Equipment
bc:Equipment rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ExteriorComponent
bc:ExteriorComponent rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bc:AboveGround
                                                                bc:BuildingComponent
                                                                bc:External
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     owl:disjointWith bc:InteriorComponent .


