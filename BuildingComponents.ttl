prod:BatteryCharger rdf:type owl:Class ;
                    rdfs:subClassOf prod:ElectricityDistributionComponent ,
                                    prod:ElectricityEmergencyComponent ,
                                    prod:Product ,
                                    bc:BuildingComponent ;
