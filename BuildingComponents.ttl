                                                              ) ;
                                           rdf:type owl:Class
                                         ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Internal
bc:Internal rdf:type owl:Class ;
            owl:equivalentClass [ rdf:type owl:Restriction ;
                                  owl:onProperty bc:isExternal ;
                                  owl:hasValue "false"^^xsd:boolean
                                ] .


