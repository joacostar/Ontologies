<http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign> rdf:type owl:Ontology ;
                                                                      owl:imports <http://www.semanticweb.org/joaquin/ontologies/2024/10/BuildingComponents> .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#hasPipeBracingType
:hasPipeBracingType rdf:type owl:ObjectProperty ;
                    rdfs:domain bc:Piping ;
                    rdfs:range :PipeBracingType .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#hasSeismicDesignCategory
:hasSeismicDesignCategory rdf:type owl:ObjectProperty ;
                          rdfs:domain bc:BuildingProduct ;
                          rdfs:range :SeismicDesignCategory .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#hasSeismicDesignType
:hasSeismicDesignType rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#hasWallSupportType
:hasWallSupportType rdf:type owl:ObjectProperty ;
                    rdfs:domain bc:Wall ;
                    rdfs:range :WallSupportType .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#hasImportanceCoefficient
:hasImportanceCoefficient rdf:type owl:DatatypeProperty ;
                          rdfs:domain bc:BuildingProduct ;
                          rdfs:range xsd:double .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#HighSeismicity
:HighSeismicity rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :SDCD
                                                  :SDCE
                                                  :SDCF
                                                )
                                    ] ;
                rdfs:subClassOf :SeismicDesignCategory .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#LowSeismicity
:LowSeismicity rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :SDCA
                                                 :SDCB
                                               )
                                   ] ;
               rdfs:subClassOf :SeismicDesignCategory .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#PipeBracingType
:PipeBracingType rdf:type owl:Class .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#SeismicDesignCategory
:SeismicDesignCategory rdf:type owl:Class .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#SeismicDesignType
:SeismicDesignType rdf:type owl:Class .


###  http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign#WallSupportType
:WallSupportType rdf:type owl:Class .


