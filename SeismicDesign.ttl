@prefix : <https://w3id.org/utoronto/ontologies/SeismicDesign#> .
@prefix bc: <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/utoronto/ontologies/SeismicDesign> .

<https://w3id.org/utoronto/ontologies/SeismicDesign> rdf:type owl:Ontology ;
                                                                      owl:imports <https://w3id.org/utoronto/ontologies/BuildingComponents> .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/utoronto/ontologies/SeismicDesign#hasPipeBracingType
:hasPipeBracingType rdf:type owl:ObjectProperty ;
                    rdfs:domain bc:Piping ;
                    rdfs:range :PipeBracingType .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#hasSeismicDesignCategory
:hasSeismicDesignCategory rdf:type owl:ObjectProperty ;
                          rdfs:domain bc:BuildingProduct ;
                          rdfs:range :SeismicDesignCategory .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#hasSeismicDesignType
:hasSeismicDesignType rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#hasWallSupportType
:hasWallSupportType rdf:type owl:ObjectProperty ;
                    rdfs:domain bc:Wall ;
                    rdfs:range :WallSupportType .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/SeismicDesign#hasImportanceCoefficient
:hasImportanceCoefficient rdf:type owl:DatatypeProperty ;
                          rdfs:domain bc:BuildingProduct ;
                          rdfs:range xsd:double .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/utoronto/ontologies/SeismicDesign#HighSeismicity
:HighSeismicity rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :SDCD
                                                  :SDCE
                                                  :SDCF
                                                )
                                    ] ;
                rdfs:subClassOf :SeismicDesignCategory .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#LowSeismicity
:LowSeismicity rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :SDCA
                                                 :SDCB
                                               )
                                   ] ;
               rdfs:subClassOf :SeismicDesignCategory .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#PipeBracingType
:PipeBracingType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#SeismicDesignCategory
:SeismicDesignCategory rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#SeismicDesignType
:SeismicDesignType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/SeismicDesign#WallSupportType
:WallSupportType rdf:type owl:Class .


