###  https://w3id.org/utoronto/ontologies/BuildingComponents#MepComponent
:MepComponent rdf:type owl:Class ;
              rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#MepSystemType
:MepSystemType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#MetalFrame
:MetalFrame rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :Frame
                                                       :MadeOfMetal
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#NonLoadBearing
:NonLoadBearing rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Restriction ;
                                      owl:onProperty :isLoadBearing ;
                                      owl:hasValue "false"^^xsd:boolean
                                    ] ;
                rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#NonstructuralComponent
:NonstructuralComponent rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :BuildingComponent
                                                                   :NonLoadBearing
                                                                   [ rdf:type owl:Class ;
                                                                     owl:complementOf :MepComponent
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :BuildingComponent ;
                        owl:disjointWith :StructuralComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Panel
:Panel rdf:type owl:Class ;
       rdfs:subClassOf :BuildingComponent ,
                       :WallInfill ;
       owl:disjointWith :X-Bracing .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#PipeBracing
:PipeBracing rdf:type owl:Class ;
             rdfs:subClassOf :Restraint .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#PipeDiameter
:PipeDiameter rdf:type owl:Class ;
              rdfs:subClassOf <http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Diameter> ,
                              :ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Piping
:Piping rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:unionOf ( <https://w3id.org/product#Fitting>
                                            <https://w3id.org/product#Pipe>
                                          )
                            ] ;
        rdfs:subClassOf :MepComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Quantity
:Quantity rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Restraint
:Restraint rdf:type owl:Class ;
           rdfs:subClassOf :SupportComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#StructuralComponent
:StructuralComponent rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :BuildingComponent
                                                                :LoadBearing
                                                                [ rdf:type owl:Class ;
                                                                  owl:complementOf :MepComponent
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#SuperstructureComponent
:SuperstructureComponent rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :StructuralComponent
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :isAboveGround ;
                                                                      owl:hasValue "true"^^xsd:boolean
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#SupportComponent
:SupportComponent rdf:type owl:Class ;
                  rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Thickness
:Thickness rdf:type owl:Class ;
           rdfs:subClassOf <http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Thickness> ,
                           :ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Unit
:Unit rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#VerticalBrace
:VerticalBrace rdf:type owl:Class ;
               rdfs:subClassOf :Restraint .


