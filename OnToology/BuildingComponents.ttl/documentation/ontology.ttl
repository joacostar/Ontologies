@prefix : <https://w3id.org/utoronto/ontologies/BuildingComponents#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/utoronto/ontologies/BuildingComponents#> .

<https://w3id.org/utoronto/ontologies/BuildingComponents> rdf:type owl:Ontology ;
                                                           owl:imports <http://www.ontology-of-units-of-measure.org/resource/om-2/subset> ,
                                                                       <https://w3id.org/digitalconstruction/0.5/Materials/Subset> ,
                                                                       <https://w3id.org/product#BuildingElements> ,
                                                                       <https://w3id.org/product#Furnishing> ,
                                                                       <https://w3id.org/product#MEP> ;
                                                           <http://purl.org/dc/elements/1.1/creator> "Joaquín Acosta Reveco (j.acosta@mail.utoronto.ca)" ;
                                                           rdfs:label "Ontology of Building Components"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer
<https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer> rdf:type owl:ObjectProperty .


###  https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial
<https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial> rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute
:hasAttribute rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :BuildingComponent
                                          :BuildingComponentType
                                        )
                          ] ;
              rdfs:range :ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasComponent
:hasComponent rdf:type owl:ObjectProperty ;
              owl:inverseOf :isComponentOf ;
              rdf:type owl:TransitiveProperty ;
              rdfs:domain :BuildingProduct .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasFrame
:hasFrame rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasInfill
:hasInfill rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasQuantity
:hasQuantity rdf:type owl:ObjectProperty ;
             rdfs:domain :ComponentAttribute ;
             rdfs:range :Quantity .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasSealant
:hasSealant rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasSupport
:hasSupport rdf:type owl:ObjectProperty ;
            rdfs:domain :BuildingComponent ;
            rdfs:range :Restraint .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasUnit
:hasUnit rdf:type owl:ObjectProperty ;
         rdfs:domain :Quantity ;
         rdfs:range :Unit .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isComponentOf
:isComponentOf rdf:type owl:ObjectProperty .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isInSystemOfType
:isInSystemOfType rdf:type owl:ObjectProperty ;
                  rdfs:domain :BuildingComponent ;
                  rdfs:range :MepSystemType .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasAspectRatio
:hasAspectRatio rdf:type owl:DatatypeProperty ;
                rdfs:domain :BuildingComponent ;
                rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#hasDouble
:hasDouble rdf:type owl:DatatypeProperty ;
           rdfs:domain :Quantity ;
           rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isAboveGround
:isAboveGround rdf:type owl:DatatypeProperty ;
               rdfs:domain :BuildingComponent ;
               rdfs:range xsd:boolean ;
               owl:propertyDisjointWith :isBelowGround .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isBelowGround
:isBelowGround rdf:type owl:DatatypeProperty ;
               rdfs:domain :BuildingComponent ;
               rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isExternal
:isExternal rdf:type owl:DatatypeProperty ;
            rdfs:domain :BuildingComponent ;
            rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isInternal
:isInternal rdf:type owl:DatatypeProperty ;
            rdfs:domain :BuildingComponent ;
            rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isLoadBearing
:isLoadBearing rdf:type owl:DatatypeProperty ;
               rdfs:domain :BuildingComponent ;
               rdfs:range xsd:boolean .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#isMonolithic
:isMonolithic rdf:type owl:DatatypeProperty ;
              rdfs:domain :BuildingComponent ;
              rdfs:range xsd:boolean .


#################################################################
#    Classes
#################################################################

###  http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Diameter
<http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Diameter> rdf:type owl:Class .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/subset/Thickness
