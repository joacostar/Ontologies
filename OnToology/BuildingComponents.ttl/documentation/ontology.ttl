                                                   owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial> ;
                                                                        owl:hasValue <https://w3id.org/digitalconstruction/0.5/Materials/Subset#Aluminium>
                                                                      ]
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer> ;
                                                   owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial> ;
                                                                        owl:hasValue <https://w3id.org/digitalconstruction/0.5/Materials/Subset#Metal>
                                                                      ]
