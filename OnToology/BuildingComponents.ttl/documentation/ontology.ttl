###  https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround
:AboveGround rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty :isAboveGround ;
                                   owl:hasValue "true"^^xsd:boolean
                                 ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#AirDistributionComponent
:AirDistributionComponent rdf:type owl:Class ;
                          rdfs:subClassOf :MepComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround
:BelowGround rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty :isAboveGround ;
                                   owl:hasValue "false"^^xsd:boolean
                                 ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Building
:Building rdf:type owl:Class ;
          rdfs:subClassOf :BuildingProduct ;
          owl:disjointWith :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent
:BuildingComponent rdf:type owl:Class ;
                   rdfs:subClassOf <https://w3id.org/product#Product> ,
                                   :BuildingProduct .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType
:BuildingComponentType rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingProduct
:BuildingProduct rdf:type owl:Class ;
                 rdfs:subClassOf <https://w3id.org/product#Product> .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Clearance
:Clearance rdf:type owl:Class ;
           rdfs:subClassOf :ComponentAttribute .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ColdFormedFrame
:ColdFormedFrame rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :Frame
                                                            :MadeOfColdFormedSteel
                                                          ) ;
                                       rdf:type owl:Class
                                     ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ColdFormedSteelFramed
:ColdFormedSteelFramed rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Restriction ;
                                             owl:onProperty :hasFrame ;
                                             owl:someValuesFrom :ColdFormedFrame
                                           ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ComponentAttribute
:ComponentAttribute rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Ducting
:Ducting rdf:type owl:Class ;
         owl:equivalentClass [ rdf:type owl:Class ;
                               owl:unionOf ( <https://w3id.org/product#Duct>
                                             <https://w3id.org/product#DuctTransition>
                                             <https://w3id.org/product#Fitting>
                                           )
                             ] ;
         rdfs:subClassOf :AirDistributionComponent ,
                         :MepComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Equipment
:Equipment rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#ExteriorComponent
:ExteriorComponent rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :AboveGround
                                                              :BuildingComponent
                                                              :External
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   owl:disjointWith :InteriorComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#External
:External rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Restriction ;
                                owl:onProperty :isExternal ;
                                owl:hasValue "true"^^xsd:boolean
                              ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Floor
:Floor rdf:type owl:Class .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Frame
:Frame rdf:type owl:Class ;
       rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Furnishing
:Furnishing rdf:type owl:Class ;
            rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Infilled
:Infilled rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Restriction ;
                                owl:onProperty <https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer> ;
                                owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial> ;
                                                     owl:someValuesFrom <https://w3id.org/digitalconstruction/0.5/Materials/Subset#Material>
                                                   ]
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasInfill ;
                                owl:someValuesFrom :WallInfill
                              ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#InteriorComponent
:InteriorComponent rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :BuildingComponent
                                                              :Internal
                                                            ) ;
                                         rdf:type owl:Class
                                       ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Internal
:Internal rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Restriction ;
                                owl:onProperty :isExternal ;
                                owl:hasValue "false"^^xsd:boolean
                              ] .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#LateralBrace
:LateralBrace rdf:type owl:Class ;
              rdfs:subClassOf :Restraint .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#Layer
:Layer rdf:type owl:Class ;
       rdfs:subClassOf :BuildingComponent .


###  https://w3id.org/utoronto/ontologies/BuildingComponents#LoadBearing
:LoadBearing rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty :isLoadBearing ;
                                   owl:hasValue "true"^^xsd:boolean
                                 ] ;
             rdfs:subClassOf :BuildingComponent ;
             owl:disjointWith :NonLoadBearing .


