<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/utoronto/ontologies/BuildingComponents#"
     xml:base="https://w3id.org/utoronto/ontologies/BuildingComponents"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents">
        <owl:imports rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/subset"/>
        <owl:imports rdf:resource="https://w3id.org/digitalconstruction/0.5/Materials/Subset"/>
        <owl:imports rdf:resource="https://w3id.org/product#BuildingElements"/>
        <owl:imports rdf:resource="https://w3id.org/product#Furnishing"/>
        <owl:imports rdf:resource="https://w3id.org/product#MEP"/>
        <dc:creator>Joaquín Acosta Reveco (j.acosta@mail.utoronto.ca)</dc:creator>
        <rdfs:label xml:lang="en">Ontology of Building Components</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasLayer"/>
    


    <!-- https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/digitalconstruction/0.5/Materials/Subset#hasMaterial"/>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasAttribute">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponentType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#ComponentAttribute"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasComponent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasComponent">
        <owl:inverseOf rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#isComponentOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingProduct"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasFrame -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasFrame"/>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasInfill -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasInfill"/>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasQuantity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasQuantity">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#ComponentAttribute"/>
        <rdfs:range rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#Quantity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasSealant -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasSealant"/>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasSupport -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasSupport">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#Restraint"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasUnit">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#Quantity"/>
        <rdfs:range rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#Unit"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isComponentOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isComponentOf"/>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isInSystemOfType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isInSystemOfType">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#MepSystemType"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasAspectRatio -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasAspectRatio">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#hasDouble -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#hasDouble">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isAboveGround -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isAboveGround">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:propertyDisjointWith rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#isBelowGround"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isBelowGround -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isBelowGround">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isExternal -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isExternal">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isInternal -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isInternal">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isLoadBearing -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isLoadBearing">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/utoronto/ontologies/BuildingComponents#isMonolithic -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#isMonolithic">
        <rdfs:domain rdf:resource="https://w3id.org/utoronto/ontologies/BuildingComponents#BuildingComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


