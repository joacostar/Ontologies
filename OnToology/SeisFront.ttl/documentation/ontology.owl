    <!-- https://w3id.org/utoronto/ontologies/SeisFront#A -->


    <owl:Class rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#A">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/product#Foundation"/>
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/utoronto/ontologies/SeisFront#FragilityCategory"/>
        <dc:description xml:lang="en">Substructure</dc:description>
        <dc:identifier>A</dc:identifier>
    </owl:Class>
    


    <!-- https://w3id.org/utoronto/ontologies/SeisFront#A10 -->


    <owl:Class rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#A10">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/product#Foundation"/>
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#A"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://w3id.org/utoronto/ontologies/SeisFront#A20 -->


    <owl:Class rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#A20">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround"/>
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#A"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://w3id.org/utoronto/ontologies/SeisFront#B -->


    <owl:Class rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#B">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/SeisFront#VulnerableComponent"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/product#Roof"/>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround"/>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#StructuralComponent"/>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#External"/>
                                                    <rdf:Description rdf:about="https://w3id.org/utoronto/ontologies/BuildingComponents#NonstructuralComponent"/>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:unionOf>
                                    </owl:Class>
