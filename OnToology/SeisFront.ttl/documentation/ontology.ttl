###  https://w3id.org/utoronto/ontologies/SeisFront#A
:A rdf:type owl:Class ;
   owl:equivalentClass [ rdf:type owl:Class ;
                         owl:unionOf ( <https://w3id.org/product#Foundation>
                                       <https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround>
                                     )
                       ] ;
   rdfs:subClassOf :FragilityCategory ;
   <http://purl.org/dc/elements/1.1/description> "Substructure"@en ;
   <http://purl.org/dc/elements/1.1/identifier> "A" .


###  https://w3id.org/utoronto/ontologies/SeisFront#A10
:A10 rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/product#Foundation>
                                                :A
                                              ) ;
                           rdf:type owl:Class
                         ] .


###  https://w3id.org/utoronto/ontologies/SeisFront#A20
:A20 rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#BelowGround>
                                                :A
                                              ) ;
                           rdf:type owl:Class
                         ] .


###  https://w3id.org/utoronto/ontologies/SeisFront#B
:B rdf:type owl:Class ;
   owl:equivalentClass [ owl:intersectionOf ( :VulnerableComponent
                                              [ rdf:type owl:Class ;
                                                owl:unionOf ( <https://w3id.org/product#Roof>
                                                              [ owl:intersectionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#AboveGround>
                                                                                     [ rdf:type owl:Class ;
                                                                                       owl:unionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#StructuralComponent>
                                                                                                     [ owl:intersectionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#External>
                                                                                                                            <https://w3id.org/utoronto/ontologies/BuildingComponents#NonstructuralComponent>
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ]
                                                                                                   )
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ]
                                                            )
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ;
   rdfs:subClassOf :FragilityCategory ;
   <http://purl.org/dc/elements/1.1/description> "Shell"@en ;
   <http://purl.org/dc/elements/1.1/identifier> "B" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B10
:B10 rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#StructuralComponent>
                                                :B
                                              ) ;
                           rdf:type owl:Class
                         ] ;
     <http://purl.org/dc/elements/1.1/description> "Superstructure"@en ;
     <http://purl.org/dc/elements/1.1/identifier> "B10" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B103
:B103 rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/utoronto/ontologies/BuildingComponents#MadeOfSteel>
                                                 :B10
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      <http://purl.org/dc/elements/1.1/description> "Structural Seel Elements"@en ;
      <http://purl.org/dc/elements/1.1/identifier> "B103" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B1031
:B1031 rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :B103
                                                  [ rdf:type owl:Class ;
                                                    owl:unionOf ( <https://w3id.org/product#Column>
                                                                  <https://w3id.org/product#Connection>
                                                                )
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       <http://purl.org/dc/elements/1.1/description> "Steel Columns"@en ;
       <http://purl.org/dc/elements/1.1/identifier> "B1031" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B1031.001
:B1031.001 rdf:type owl:Class ;
           rdfs:subClassOf :B1031 ;
           <http://purl.org/dc/elements/1.1/description> "Bolted shear tab gravity connections"@en ;
           <http://purl.org/dc/elements/1.1/identifier> "B1031.001" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B1031.011a
:B1031.011a rdf:type owl:Class ;
            rdfs:subClassOf :B1031 ;
            <http://purl.org/dc/elements/1.1/description> "Steel Column Base Plates, Column W < 150 plf"@en ;
            <http://purl.org/dc/elements/1.1/identifier> "B1031.011a" .


###  https://w3id.org/utoronto/ontologies/SeisFront#B1031.011b
:B1031.011b rdf:type owl:Class ;
            rdfs:subClassOf :B1031 ;
            <http://purl.org/dc/elements/1.1/description> "Steel Column Base Plates, Column 150 plf < W < 300 plf"@en ;
