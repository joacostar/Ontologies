                         rdfs:range xsd:string .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasTag
:hasTag rdf:type owl:DatatypeProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcElement>
                                    <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#IfcTypeProduct>
                                  )
                    ] ;
        rdfs:range xsd:string .


