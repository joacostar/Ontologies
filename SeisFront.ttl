                                                                              owl:hasValue om2:squareFoot-International
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty om2:hasNumericalValue ;
                                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                                   owl:onDatatype xsd:double ;
                                                                                                   owl:withRestrictions ( [ xsd:minExclusive "2500.0"^^xsd:double
                                                                                                                          ]
                                                                                                                        )
                                                                                                 ]
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
