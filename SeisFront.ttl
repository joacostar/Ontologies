                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty om2:hasNumericalValue ;
                                                                                 owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                                      owl:onDatatype xsd:double ;
                                                                                                      owl:withRestrictions ( [ xsd:minExclusive "1000.0"^^xsd:double
                                                                                                                             ]
                                                                                                                           )
                                                                                                    ]
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty om2:hasNumericalValue ;
                                                                                 owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                                      owl:onDatatype xsd:double ;
                                                                                                      owl:withRestrictions ( [ xsd:maxInclusive "2500.0"^^xsd:double
                                                                                                                             ]
                                                                                                                           )
                                                                                                    ]
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf sfront:Thresholds .


