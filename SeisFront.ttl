<http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront> rdf:type owl:Ontology ;
                                                                   owl:imports <http://www.ontology-of-units-of-measure.org/resource/om-2/subset> ,
                                                                               <http://www.semanticweb.org/joaquin/ontologies/2024/10/BuildingComponents> ,
                                                                               <http://www.semanticweb.org/joaquin/ontologies/2024/7/SeismicDesign> ,
                                                                               <https://w3id.org/digitalconstruction/0.5/Materials/Subset> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/joaquin/ontologies/2024/10/BuildingComponents#hasComponent
bc:hasComponent rdfs:range bc:BuildingComponent .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#hasOccupancyType
sfront:hasOccupancyType rdf:type owl:ObjectProperty ;
                        rdfs:domain bc:BuildingProduct ;
                        rdfs:range sfront:Occupancy .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#isInWeatherType
sfront:isInWeatherType rdf:type owl:ObjectProperty ;
                       rdfs:domain bc:BuildingProduct ;
                       rdfs:range sfront:WeatherType .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/joaquin/ontologies/2024/10/BuildingComponents#MadeOfStucco
bc:MadeOfStucco rdf:type owl:Class .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#A
sfront:A rdf:type owl:Class ;
         owl:equivalentClass [ rdf:type owl:Class ;
                               owl:unionOf ( bc:BelowGround
                                             prod:Foundation
                                           )
                             ] ;
         rdfs:subClassOf sfront:FragilityCategory ;
         dc:description "Substructure"@en ;
         dc:identifier "A" .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#A10
sfront:A10 rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( sfront:A
                                                      prod:Foundation
                                                    ) ;
                                 rdf:type owl:Class
                               ] .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#A20
sfront:A20 rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( bc:BelowGround
                                                      sfront:A
                                                    ) ;
                                 rdf:type owl:Class
                               ] .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#B
sfront:B rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( sfront:VulnerableComponent
                                                    [ rdf:type owl:Class ;
                                                      owl:unionOf ( prod:Roof
                                                                    [ owl:intersectionOf ( bc:AboveGround
                                                                                           [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( bc:StructuralComponent
                                                                                                           [ owl:intersectionOf ( bc:External
                                                                                                                                  bc:NonstructuralComponent
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ]
                                                                                                         )
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ]
                                                                  )
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf sfront:FragilityCategory ;
         dc:description "Shell"@en ;
         dc:identifier "B" .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#B10
sfront:B10 rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( bc:StructuralComponent
                                                      sfront:B
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           dc:description "Superstructure"@en ;
           dc:identifier "B10" .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#B103
sfront:B103 rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( bc:MadeOfSteel
                                                       sfront:B10
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            dc:description "Structural Seel Elements"@en ;
            dc:identifier "B103" .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#B1031
sfront:B1031 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( sfront:B103
                                                        [ rdf:type owl:Class ;
                                                          owl:unionOf ( prod:Column
                                                                        prod:Connection
                                                                      )
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             dc:description "Steel Columns"@en ;
             dc:identifier "B1031" .


###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#B1031.001
sfront:B1031.001 rdf:type owl:Class ;
                 rdfs:subClassOf sfront:B1031 ;
                 dc:description "Bolted shear tab gravity connections"@en ;
                 dc:identifier "B1031.001" .


