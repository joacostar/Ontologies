###  http://www.semanticweb.org/joaquin/ontologies/2025/05/SeisFront#GreaterThan2.5Inches
sfront:GreaterThan2.5Inches rdf:type owl:Class ;
                            owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                         owl:onProperty om2:hasUnit ;
                                                                         owl:hasValue om2:inch-International
                                                                       ]
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty om2:hasNumericalValue ;
                                                                         owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                              owl:onDatatype xsd:double ;
                                                                                              owl:withRestrictions ( [ xsd:minExclusive "2.5"^^xsd:double
                                                                                                                     ]
                                                                                                                   )
                                                                                            ]
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ] ;
                            rdfs:subClassOf sfront:Thresholds .


