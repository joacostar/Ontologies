@prefix : <https://w3id.org/utoronto/ontologies/IfcLit#> .
@prefix ifc: <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dicm: <https://w3id.org/digitalconstruction/0.5/Materials/Subset#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ifcLit: <https://w3id.org/utoronto/ontologies/IfcLit#> .
@base <https://w3id.org/utoronto/ontologies/IfcLit#> .

<https://w3id.org/utoronto/ontologies/IfcLit> rdf:type owl:Ontology ;
                                               owl:imports <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL> ,
                                                           <https://w3id.org/digitalconstruction/0.5/Materials/Subset> ;
                                               <http://purl.org/dc/elements/1.1/creator> "Joaquín Acosta Reveco (j.acosta@mail.utoronto.ca)" ;
                                               rdfs:label "Light version of ifcOWL Ontology"@en .

#################################################################
#    Object Properties
#################################################################

###  https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#relatedObjects_IfcRelDefinesByProperties
ifc:relatedObjects_IfcRelDefinesByProperties owl:inverseOf ifcLit:isDefinedBy_IfcObject .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterial
ifcLit:hasMaterial rdf:type owl:ObjectProperty ;
                   owl:inverseOf ifcLit:isMaterialOf ;
                   rdfs:domain ifc:IfcObjectDefinition ;
                   rdfs:range ifc:IfcMaterialDefinition .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasMaterialReference
ifcLit:hasMaterialReference rdf:type owl:ObjectProperty ;
                            rdfs:domain ifc:IfcMaterialDefinition ;
                            rdfs:range dicm:Material .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalComplexQuantity
ifcLit:hasPhysicalComplexQuantity rdf:type owl:ObjectProperty ;
                                  rdfs:domain ifc:IfcRoot ;
                                  rdfs:range ifc:IfcPhysicalComplexQuantity .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPhysicalSimpleQuantity
ifcLit:hasPhysicalSimpleQuantity rdf:type owl:ObjectProperty ;
                                 rdfs:domain ifc:IfcRoot ;
                                 rdfs:range ifc:IfcPhysicalSimpleQuantity .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasProperty
ifcLit:hasProperty rdf:type owl:ObjectProperty ;
                   rdfs:domain ifc:IfcRoot ;
                   rdfs:range ifc:IfcPropertyAbstraction .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasPropertySingleValue
ifcLit:hasPropertySingleValue rdf:type owl:ObjectProperty ;
                              rdfs:domain ifc:IfcRoot ;
                              rdfs:range ifc:IfcPropertySingleValue .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasType
ifcLit:hasType rdf:type owl:ObjectProperty ;
               rdfs:domain ifc:IfcObject ;
               rdfs:range ifc:IfcTypeObject .


###  https://w3id.org/utoronto/ontologies/IfcLit#isDefinedBy_IfcObject
ifcLit:isDefinedBy_IfcObject rdf:type owl:ObjectProperty ;
                             rdfs:label "IsDefinedBy" .


###  https://w3id.org/utoronto/ontologies/IfcLit#isInDistributionSystemPredefinedType
ifcLit:isInDistributionSystemPredefinedType rdf:type owl:ObjectProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain ifc:IfcObjectDefinition ;
                                            rdfs:range ifc:IfcDistributionSystemEnum .


###  https://w3id.org/utoronto/ontologies/IfcLit#isInGroup
ifcLit:isInGroup rdf:type owl:ObjectProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:domain ifc:IfcObjectDefinition ;
                 rdfs:range ifc:IfcGroup .


###  https://w3id.org/utoronto/ontologies/IfcLit#isMaterialOf
ifcLit:isMaterialOf rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/utoronto/ontologies/IfcLit#hasAreaValue_IfcQuantityArea
ifcLit:hasAreaValue_IfcQuantityArea rdf:type owl:DatatypeProperty ;
                                    rdfs:domain ifc:IfcQuantityArea ;
                                    rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasGlobalId
ifcLit:hasGlobalId rdf:type owl:DatatypeProperty ;
                   rdfs:domain ifc:IfcRoot ;
                   rdfs:range xsd:string .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasLengthValue_IfcQuantityLength
ifcLit:hasLengthValue_IfcQuantityLength rdf:type owl:DatatypeProperty ;
                                        rdfs:domain ifc:IfcQuantityLength ;
                                        rdfs:range xsd:double .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasName
ifcLit:hasName rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( ifc:IfcPhysicalQuantity
                                           ifc:IfcPropertySingleValue
                                           ifc:IfcRoot
                                         )
                           ] ;
               rdfs:range xsd:string .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasObjectType_IfcObject
ifcLit:hasObjectType_IfcObject rdf:type owl:DatatypeProperty ;
                               rdfs:domain ifc:IfcObject ;
                               rdfs:range xsd:string .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasTag
ifcLit:hasTag rdf:type owl:DatatypeProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( ifc:IfcElement
                                          ifc:IfcTypeProduct
                                        )
                          ] ;
              rdfs:range xsd:string .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasValue_IfcPropertySingleValue
ifcLit:hasValue_IfcPropertySingleValue rdf:type owl:DatatypeProperty ;
                                       rdfs:domain ifc:IfcPropertySingleValue .


###  https://w3id.org/utoronto/ontologies/IfcLit#hasVolumeValue_IfcQuantityVolume
ifcLit:hasVolumeValue_IfcQuantityVolume rdf:type owl:DatatypeProperty ;
                                        rdfs:domain ifc:IfcQuantityVolume ;
                                        rdfs:range xsd:double .


